{
  "name": "ernestdefoe/cross-references",
  "description": "GitHub-style cross-references between discussions and posts on Flarum 2: #123 inline references, pasted-URL detection, bidirectional backlinks, optional notifications, search filter, and a sidebar widget of inbound references.",
  "type": "flarum-extension",
  "keywords": ["flarum", "discussions", "references", "backlinks", "mentions"],
  "license": "MIT",
  "authors": [
    {
      "name": "Ernestdefoe",
      "email": "ernestdefoe@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "flarum/core": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Ernestdefoe\\CrossReferences\\": "src/"
    }
  },
  "extra": {
    "flarum-extension": {
      "title": "Cross References",
      "category": "feature",
      "icon": {
        "name": "fas fa-link",
        "backgroundColor": "#2c5282",
        "color": "#ffffff"
      }
    },
    "flarum-cli": {
      "modules": {
        "admin": true,
        "forum": true,
        "js": true,
        "jsCommon": false,
        "css": true,
        "locale": true,
        "gitConf": true,
        "githubActions": false,
        "prettier": false,
        "typescript": false,
        "bundlewatch": false,
        "backendTesting": false,
        "editorConfig": false,
        "styleci": false
      }
    }
  }
}
